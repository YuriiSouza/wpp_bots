// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // directUrl = env("DIRECT_URL")
  shadowDatabaseUrl = env("SHADOW_DB")
}

model Driver {
  id                           String   @id
  name                         String?
  hubId                        String?
  vehicleType                  String?
  ds                           String?
  noShowCount                  Int      @default(0)
  declineRate                  Float    @default(0)
  priorityScore                Float    @default(0)
  updatedAt                    DateTime @updatedAt
  createdAt                    DateTime @default(now())

  hub                          Hub?     @relation(fields: [hubId], references: [id])
  routes                        Route[] @relation("RouteDriver")
  supportTickets               SupportTicket[]

  @@index([hubId])
}

model ConversationState {
  phone          String   @id
  step           String   // "ASK_DRIVER_ID" | "DONE"
  lastDriverId   String?
  updatedAt      DateTime @updatedAt
  createdAt      DateTime @default(now())
}

model Route {
  id                        String      @id
  atId                      String
  routeDate                 String?
  shift                     String?
  gaiola                    String?
  bairro                    String?
  cidade                    String?
  requiredVehicleType       String?
  requiredVehicleTypeNorm   String?
  suggestionDriverDs        String?
  km                        String?
  spr                       String?
  volume                    String?
  gg                        String?
  veiculoRoterizado         String?
  requestedDriverId         String?
  botAvailable              Boolean     @default(false)
  assignmentSource          RouteAssignmentSource @default(SYNC)
  noShow                    Boolean     @default(false)
  sheetRowNumber            Int?
  driverId                  String?
  driverName                String?
  driverVehicleType         String?
  driverAccuracy            String?
  driverPlate               String?
  status                    RouteStatus @default(DISPONIVEL)
  assignedAt                DateTime?
  updatedAt                 DateTime    @updatedAt
  createdAt                 DateTime    @default(now())

  driver                    Driver?     @relation("RouteDriver", fields: [driverId], references: [id])

  @@index([atId, routeDate])
  @@index([routeDate, shift])
  @@index([noShow, status])
}

model SyncLog {
  id               String   @id @default(uuid())
  status           String
  startedAt        DateTime @default(now())
  finishedAt       DateTime?
  driversCount     Int      @default(0)
  routesAvailable  Int      @default(0)
  routesAssigned   Int      @default(0)
  message          String?
}

model AssignmentOverview {
  id         String   @id @default(uuid())
  rowNumber  Int      @unique
  driverId   String?
  payload    Json
  updatedAt  DateTime @updatedAt
  createdAt  DateTime @default(now())

  @@index([driverId])
}

model Hub {
  id            String          @id
  name          String
  timezone      String          @default("America/Sao_Paulo")
  isActive      Boolean         @default(true)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  drivers       Driver[]
  analysts      Analyst[]
  supportTickets SupportTicket[]
}

model Analyst {
  id            String       @id
  name          String
  email         String       @unique
  password      String
  telegramChatId String?
  role          AnalystRole
  hubId         String?
  isActive      Boolean      @default(true)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  hub           Hub?         @relation(fields: [hubId], references: [id])
  supportTickets SupportTicket[]
  supportMessages SupportMessage[]

  @@index([hubId])
  @@index([role])
}

model SupportTicket {
  id              String              @id @default(uuid())
  protocol        String              @unique
  status          SupportTicketStatus @default(WAITING_ANALYST)
  driverId        String
  hubId           String
  analystId       String?
  queuePosition   Int?
  waitingSince    DateTime            @default(now())
  firstResponseAt DateTime?
  closedAt        DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  driver          Driver              @relation(fields: [driverId], references: [id])
  hub             Hub                 @relation(fields: [hubId], references: [id])
  analyst         Analyst?            @relation(fields: [analystId], references: [id])
  messages        SupportMessage[]

  @@index([hubId, status])
  @@index([driverId])
  @@index([analystId])
  @@index([updatedAt])
}

model SupportMessage {
  id           String            @id @default(uuid())
  ticketId     String
  authorType   SupportAuthorType
  authorId     String?
  authorName   String
  body         String
  telegramText String
  createdAt    DateTime          @default(now())

  ticket       SupportTicket     @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  analyst      Analyst?          @relation(fields: [authorId], references: [id])

  @@index([ticketId, createdAt])
}

model AuditLog {
  id         String   @id @default(uuid())
  entityType String
  entityId   String
  action     String
  userId     String?
  userName   String
  before     Json?
  after      Json?
  createdAt  DateTime @default(now())

  @@index([entityType, createdAt])
  @@index([userId, createdAt])
}

model SystemConfig {
  key        String   @id
  value      Json
  updatedAt  DateTime @updatedAt
  createdAt  DateTime @default(now())
}

model DriverBlocklist {
  driverId           String          @id
  status             BlocklistStatus @default(BLOCKED)
  timesListed        Int             @default(1)
  lastActivatedAt    DateTime?
  lastInactivatedAt  DateTime?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  @@index([status])
  @@index([updatedAt])
}

model FaqItem {
  id        String   @id @default(uuid())
  title     String
  answer    String
  position  Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([active, position])
}

enum RouteStatus {
  DISPONIVEL
  ATRIBUIDA
  BLOQUEADA
}

enum RouteAssignmentSource {
  SYNC
  MANUAL
  TELEGRAM_BOT
}

enum BlocklistStatus {
  BLOCKED
  UNBLOCKED
}

enum AnalystRole {
  ADMIN
  ANALISTA
  SUPERVISOR
}

enum SupportTicketStatus {
  WAITING_ANALYST
  IN_PROGRESS
  WAITING_DRIVER
  CLOSED
}

enum SupportAuthorType {
  DRIVER
  ANALYST
  SYSTEM
}
